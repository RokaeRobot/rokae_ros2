  <xacro:include filename="$(find rokae_description)/urdf/materials.xacro" />
  <xacro:property name="nameofManipulator" value = "xMateER7"/>

  <!-- Used for fixing robot to Gazebo 'base_link' -->
  <link name="world"/>
  <joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="xMate7_base"/>
  </joint>


  <!--base-->
  <link name="xMate7_base">
    <visual>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/visual/xMate7_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://rokae_description/meshes/${nameofManipulator}/collision/xMate7_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
  </link>
  <joint name="xMate7_joint_1" type="revolute">
    <parent link="xMate7_base"/>
    <child link="xMate7_link1"/>
    <limit effort="217" lower="-2.9671" upper="2.9671" velocity="1.5707963267948966"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
  </joint>
  <transmission name="tran1">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="xMate7_joint_7">
      <hardwareInterface>EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor1">
      <hardwareInterface>EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
