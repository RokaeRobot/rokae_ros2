  </transmission>
  <gazebo reference="joint1">
    <kp>1000.0</kp>
    <kd>100.0</kd>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
    <friction1>0.0</friction1>
    <friction2>0.0</friction2>
  </gazebo>
  <gazebo reference="joint2">
    <kp>1000.0</kp>
    <kd>100.0</kd>
    <mu1>0.1</mu1>
