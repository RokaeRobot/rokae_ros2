      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/visual/${nameofManipulator}_link7.stl" scale="0.001 0.001 0.001"/>
      </geometry>
	<origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    
    <inertial>
      
      <mass value="1.26834"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.0201" iyz="0" izz="0.02337"/>
      <origin rpy="0 0 0" xyz="0 0.012 -0.052"/>

    </inertial>
    
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/collision/${nameofManipulator}_link7.stl" scale="0.001 0.001 0.001"/>
      </geometry>
	<origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  
  <!-- GAZEBO_ADDED_BEGIN -->
  <transmission name="tran1">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint1">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor1">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="tran2">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint2">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor2">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="tran3">
