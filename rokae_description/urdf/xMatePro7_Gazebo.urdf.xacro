<?xml version="1.0"?>
<!-- xmate3 manipulator -->

<!--  Attention!!! inertia in the model is not correct!!! -->

<robot name="xMatePro7" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="mesh_prefix" default="package://rokae_description/meshes"/>

  <!-- Constants for robot dimensions -->
 
  <!-- Import all Gazebo-customization elements, including Gazebo colors -->
  <!--xacro:include filename="$(find XB06_description)/urdf/XB06.gazebo" /-->
  <!-- Import Rviz colors -->
  <xacro:include filename="$(find rokae_description)/urdf/materials.xacro" />
  <xacro:property name="nameofManipulator" value = "xMatePro7"/>

  <!-- Used for fixing robot to Gazebo 'base_link' -->
  <link name="world"/>
    <joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="${nameofManipulator}_base"/>
  </joint>
  
 


<!--base-->
  <link name="${nameofManipulator}_base">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/visual/${nameofManipulator}_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
       <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
       <material name="white"/>
    </visual>
    <inertial>
      
  <mass value="5.48267"/>
  <inertia ixx="0.026" ixy="0" ixz="0" iyy="0.0266" iyz="0" izz="0.0235"/>
  <origin rpy="0 0 0" xyz="-0.0183 0 0.067"/> 
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/collision/${nameofManipulator}_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
  </link>
  
  <joint name="joint1" type="revolute">
    <parent link="${nameofManipulator}_base"/>
    <child link="${nameofManipulator}_link1"/>
 <limit effort="217" lower="-2.9671" upper="2.9671" velocity="1.5707963267948966"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
 </joint>
  
  
  
  
<!--link 1-->  
  <link name="${nameofManipulator}_link1">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/visual/${nameofManipulator}_link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    
    <inertial>      
     <mass value="5.96204"/>
     <inertia ixx="0.0251" ixy="0" ixz="0" iyy="0.0249" iyz="0" izz="0.027176"/>
     <origin rpy="0 0 0" xyz="0 -0.017 0.320"/>

     </inertial>
    
    
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/collision/${nameofManipulator}_link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
       <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  
  <joint name="joint2" type="revolute">
    <parent link="${nameofManipulator}_link1"/>
    <child link="${nameofManipulator}_link2"/>
  <limit effort="217" lower="-2.0944" upper="2.0944" velocity="1.5707963267948966"/>
    <axis xyz="0 1 0"/>
	<origin rpy="0 0 0" xyz="0 0 0.404"/>
    </joint>
  




<!--link 2-->  
  <link name="${nameofManipulator}_link2">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/visual/${nameofManipulator}_link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
     <origin rpy="0 0 0" xyz="0 0 0.0"/>
     <material name="white"/>
    </visual>
    
    
    <inertial>
    <mass value="5.40302"/>
    <inertia ixx="0.0270" ixy="0" ixz="0" iyy="0.027230" iyz="0" izz="0.0211"/>
    <origin rpy="0 0 0" xyz="0 0.032 0.093"/>
    </inertial>
    
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/collision/${nameofManipulator}_link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.0"/>
    </collision>
  </link>
 
   
  <joint name="joint3" type="revolute">
    <parent link="${nameofManipulator}_link2"/>
    <child link="${nameofManipulator}_link3"/>
  <limit effort="102" lower="-2.9671" upper="2.9671" velocity="2.0943951023931953"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0 0 0.23743878"/>
  </joint>




<!--${nameofManipulator}_link 3--> 
  <link name="${nameofManipulator}_link3">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/visual/${nameofManipulator}_link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
	<origin rpy="0 0 0" xyz="0 0 0.15549959"/>
      <material name="white"/>
    </visual>

    <inertial>    
    <mass value="3.95735"/>
    <inertia ixx="0.022" ixy="0" ixz="0" iyy="0.021" iyz="0" izz="0.02112"/>
    <origin rpy="0 0 0" xyz="0 -0.013 -0.067"/>

    </inertial>
    
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/collision/${nameofManipulator}_link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
         <origin rpy="0 0 0" xyz="0 0 0.15549959"/>
      </collision>
  </link>
 
  <joint name="joint4" type="revolute">
    <parent link="${nameofManipulator}_link3"/>
    <child link="${nameofManipulator}_link4"/>
   <limit effort="102" lower="-2.0944" upper="2.0944" velocity="2.0943951023931953"/>
<!--     lower="-2.79" upper="2.79" -->
    <axis xyz="0 1 0"/>
<!--     <origin rpy="0 0 0" xyz="0.585 0.0 0.035"/> -->
    <origin rpy="0 0 0" xyz="0 0 0.15549959"/>
  </joint>



<!--link 4--> 
  <link name="${nameofManipulator}_link4">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/visual/${nameofManipulator}_link4.stl" scale=".001 0.001 0.001"/>
      </geometry>
	<origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    <inertial>    
    <mass value="2.91217"/>
    <inertia ixx="0.024" ixy="0" ixz="0" iyy="0.021138" iyz="0" izz="0.0205"/>
    <origin rpy="0 0 0" xyz="0 0.026 0.068"/>

    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/collision/${nameofManipulator}_link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
	<origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
  </link>
  
  
  <joint name="joint5" type="revolute">
    <parent link="${nameofManipulator}_link4"/>
    <child link="${nameofManipulator}_link5"/>
  <limit effort="66" lower="-2.9671" upper="2.9671" velocity="2.0943951023931953"/>
    <axis xyz="0 0 1"/>
   <origin rpy="0 0 0" xyz="0 0 0.22044633"/>
  </joint>






<!--link 5--> 
  <link name="${nameofManipulator}_link5">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/visual/${nameofManipulator}_link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
       <origin rpy="0 0 0" xyz="0 0 0.14512568"/>
      <material name="white"/>
      </visual>

    <inertial>

    <mass value="2.47056"/>
    <inertia ixx="0.019" ixy="0" ixz="0" iyy="0.018" iyz="0" izz="0.02339"/>
    <origin rpy="0 0 0" xyz="0 -0.014 -0.079"/>

    </inertial>
    
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/collision/${nameofManipulator}_link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
       <origin rpy="0 0 0" xyz="0 0 0.14512568"/>
    </collision>
  </link>
  
  <joint name="joint6" type="revolute">
    <parent link="${nameofManipulator}_link5"/>
    <child link="${nameofManipulator}_link6"/>
   <limit effort="66" lower="-2.0944" upper="2.0944" velocity="2.0943951023931953"/>
    <axis xyz="0 1 0"/>
    <origin rpy="0.0 0.0 0" xyz="0 0 0.14512568" />
  </joint>





<!--link 6--> 
  <link name="${nameofManipulator}_link6">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/visual/${nameofManipulator}_link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
	<origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    
    <inertial>
      <mass value="2.16053"/>
    <inertia ixx="0.016" ixy="0" ixz="0" iyy="0.02351" iyz="-0" izz="0.0203"/>
      <origin rpy="0 0 0" xyz="0 0.020 0.085"/>
    </inertial>
    
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMatePro7/collision/${nameofManipulator}_link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
	<origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
  </link>

  <joint name="joint7" type="revolute">
    <parent link="${nameofManipulator}_link6"/>
    <child link="${nameofManipulator}_link7"/>
   <limit effort="66" lower="-6.2832" upper="6.2832" velocity="2.0943951023931953"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0.0 0.0 0.0" xyz="0 0 0.25090877" />
  </joint>

<!--link 7--> 
  <link name="${nameofManipulator}_link7">
