<?xml version="1.0"?>
<robot name="xMateSR3" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:include filename="$(find rokae_description)/urdf/materials.xacro" />
  <xacro:arg name="mesh_prefix" default="package://rokae_description/meshes"/>
  <xacro:property name="nameofManipulator" value="xMateSR3"/>

  <xacro:macro name="rokae_joint_gazebo" params="joint_name">
    <gazebo reference="${joint_name}">
      <kp>1000.0</kp>
      <kd>100.0</kd>
      <mu1>0.1</mu1>
      <mu2>0.1</mu2>
      <friction1>0.0</friction1>
      <friction2>0.0</friction2>
    </gazebo>
  </xacro:macro>

  <xacro:macro name="rokae_link_gazebo" params="link_ref">
    <gazebo reference="${link_ref}">
      <material>Gazebo/Blue</material>
      <collision>
        <laser_retro>0.5</laser_retro>
      </collision>
    </gazebo>
  </xacro:macro>

  <link name="${nameofManipulator}_base">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </inertial>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_base"/>

  <joint name="joint1" type="revolute">
    <parent link="${nameofManipulator}_base"/>
    <child link="${nameofManipulator}_link1"/>
    <limit effort="66" lower="-3.0543" upper="3.0543" velocity="3.141592653589793"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.334"/>
    <dynamics damping="40.0" friction="2.0"/>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint1"/>
  <transmission name="tran1">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint1">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor1">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link1">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="2.727"/>
      <inertia ixx="0.02398503" ixy="-0.00000018" ixz="-0.00000263" iyy="0.02354257" iyz="-0.00198845" izz="0.00487730"/>
      <origin rpy="0 0 0" xyz="1.2e-05 -0.007924 0.248734"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link1"/>

  <joint name="joint2" type="revolute">
    <parent link="${nameofManipulator}_link1"/>
    <child link="${nameofManipulator}_link2"/>
    <limit effort="66" lower="-2.3562" upper="2.2689" velocity="3.141592653589793"/>
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    <dynamics damping="40.0" friction="2.0"/>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint2"/>
  <transmission name="tran2">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint2">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor2">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link2">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="3.179"/>
      <inertia ixx="0.06130730" ixy="0.00049744" ixz="0.00865453" iyy="0.06142986" iyz="-0.00030149" izz="0.00893295"/>
      <origin rpy="0 0 0" xyz="0.018501 -0.06886199999999999 0.142338"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link2"/>

  <joint name="joint3" type="revolute">
    <parent link="${nameofManipulator}_link2"/>
    <child link="${nameofManipulator}_link3"/>
    <limit effort="29" lower="-3.0543" upper="2.3562" velocity="3.141592653589793"/>
    <axis xyz="0 -1 0"/>
    <origin rpy="0 0 0" xyz="0.05 0.0 0.29"/>
    <dynamics damping="40.0" friction="2.0"/>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint3"/>
  <transmission name="tran3">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint3">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor3">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link3">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="1.601"/>
      <inertia ixx="0.00648999" ixy="-0.00052508" ixz="0.00171012" iyy="0.00702354" iyz="-0.00081823" izz="0.00329616"/>
      <origin rpy="0 0 0" xyz="0.025033999999999997 0.011526 0.041307"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link3"/>

  <joint name="joint4" type="revolute">
    <parent link="${nameofManipulator}_link3"/>
    <child link="${nameofManipulator}_link4"/>
    <limit effort="16" lower="-3.0543" upper="3.0543" velocity="3.141592653589793"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="-0.05 0.0 0.29"/>
    <dynamics damping="40.0" friction="2.0"/>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint4"/>
  <transmission name="tran4">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint4">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor4">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link4">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link4.stl" scale=".001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="1.882"/>
      <inertia ixx="0.01331985" ixy="-0.00000185" ixz="0.00000087" iyy="0.01251989" iyz="-0.00143894" izz="0.00278828"/>
      <origin rpy="0 0 0" xyz="-2.5e-05 -0.010923 -0.071267"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link4"/>

  <joint name="joint5" type="revolute">
    <parent link="${nameofManipulator}_link4"/>
    <child link="${nameofManipulator}_link5"/>
    <limit effort="16" lower="-3.0543" upper="3.0543" velocity="3.141592653589793"/>
    <axis xyz="0 -1 0"/>
    <origin rpy="0 0 0" xyz="0.0 0.136 0.0"/>
    <dynamics damping="40.0" friction="2.0"/>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint5"/>
  <transmission name="tran5">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint5">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor5">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link5">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="1.507"/>
      <inertia ixx="0.00503262" ixy="-0.00000608" ixz="-0.00000129" iyy="0.00261442" iyz="-0.00033165" izz="0.00394480"/>
      <origin rpy="0 0 0" xyz="3e-06 0.029172999999999998 0.007019"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link5"/>

  <joint name="joint6" type="revolute">
    <parent link="${nameofManipulator}_link5"/>
    <child link="${nameofManipulator}_link6"/>
    <limit effort="16" lower="-3.0543" upper="3.0543" velocity="3.141592653589793"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0.0 0.0 0" xyz="0.0 0.0 0.1035"/>
    <dynamics damping="40.0" friction="2.0"/>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint6"/>
  <transmission name="tran6">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint6">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor6">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link6">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="0.634"/>
      <inertia ixx="0.00099702" ixy="-0.00000138" ixz="0.00000090" iyy="0.00100253" iyz="0.00000158" izz="0.00044795"/>
      <origin rpy="0 0 0" xyz="7.3e-05 7.9e-05 -0.044853000000000004"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/${nameofManipulator}_link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link6"/>

  <ros2_control name="xMateSR3_system" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      <param name="use_sim_time">true</param>
    </hardware>
    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint5">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint6">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>$(find rokae_hardware)/config/xMateSR3_controllers.yaml</parameters>
    </plugin>
  </gazebo>
</robot>
