<?xml version='1.0' encoding='UTF-8'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="xMateSR5">
  <xacro:arg name="mesh_prefix" default="package://rokae_description/meshes"/>
  <!-- Constants for robot dimensions -->
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.423529411765 0.0392156862745 1.0"/>
  </material>
  <material name="brown">
    <color rgba="0.870588235294 0.811764705882 0.764705882353 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="Beige">
    <color rgba="1.0 0.784 0.5765 1.0"/>
  </material>
  <link name="world"/>
  <joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="xMateSR5_base"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <!--base-->
  <link name="xMateSR5_base">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMateSR5/visual/xMateSR5_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/xMateSR5/collision/xMateSR5_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </inertial>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="xMateSR5_base"/>
    <child link="xMateSR5_link1"/>
    <limit effort="113" lower="-6.2832" upper="6.2832" velocity="3.141592653589793"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.328"/>
  
    <dynamics damping="120.0" friction="4.0"/>
    <initial_position>0.0</initial_position>
  </joint>
  <!--link 1-->
