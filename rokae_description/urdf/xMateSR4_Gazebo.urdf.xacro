<?xml version="1.0"?>
<robot name="xMateSR4" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:include filename="$(find rokae_description)/urdf/materials.xacro"/>
  <xacro:arg name="mesh_prefix" default="package://rokae_description/meshes"/>
  <xacro:property name="nameofManipulator" value="xMateSR4"/>

  <link name="world"/>
  <joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="${nameofManipulator}_base"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <xacro:macro name="rokae_joint_gazebo" params="joint_name">
    <gazebo reference="${joint_name}">
      <kp>1000.0</kp>
      <kd>100.0</kd>
      <mu1>0.1</mu1>
      <mu2>0.1</mu2>
      <friction1>0.0</friction1>
      <friction2>0.0</friction2>
    </gazebo>
  </xacro:macro>

  <xacro:macro name="rokae_link_gazebo" params="link_ref">
    <gazebo reference="${link_ref}">
      <material>Gazebo/Blue</material>
      <collision>
        <laser_retro>0.5</laser_retro>
      </collision>
    </gazebo>
  </xacro:macro>

  <link name="${nameofManipulator}_base">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/visual/${nameofManipulator}_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="3.44074938"/>
      <inertia ixx="0.01764837" ixy="0" ixz="0" iyy="0.016617391" iyz="0" izz="0.011201639"/>
      <origin rpy="0 0 0" xyz="-0.000072769597 -0.001679187012 0.002986854502"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/collision/${nameofManipulator}_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_base"/>

  <joint name="joint1" type="revolute">
    <parent link="${nameofManipulator}_base"/>
    <child link="${nameofManipulator}_link1"/>
    <limit effort="102" lower="-3.0543" upper="3.0543" velocity="3.141592653589793"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0 0 0.355"/>
    <dynamics damping="120.0" friction="4.0"/>
    <initial_position>0.0</initial_position>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint1"/>
  <transmission name="tran1">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint1">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor1">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link1">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/visual/${nameofManipulator}_link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="3.430"/>
      <inertia ixx="0.034175" ixy="0" ixz="0" iyy="0.033745" iyz="0" izz="0.02009402"/>
      <origin rpy="0 0 0" xyz="0.0000102 -0.00755 0.25819"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/collision/${nameofManipulator}_link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link1"/>

  <joint name="joint2" type="revolute">
    <parent link="${nameofManipulator}_link1"/>
    <child link="${nameofManipulator}_link2"/>
    <limit effort="102" lower="-2.3562" upper="2.3562" velocity="3.141592653589793"/>
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <dynamics damping="120.0" friction="4.0"/>
    <initial_position>0.0</initial_position>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint2"/>
  <transmission name="tran2">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint2">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor2">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link2">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/visual/${nameofManipulator}_link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="4.299"/>
      <inertia ixx="0.0139827933" ixy="0" ixz="0" iyy="0.02142577" iyz="0" izz="0.01264"/>
      <origin rpy="0 0 0" xyz="0.01644 -0.069406 0.18367"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/collision/${nameofManipulator}_link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link2"/>

  <joint name="joint3" type="revolute">
    <parent link="${nameofManipulator}_link2"/>
    <child link="${nameofManipulator}_link3"/>
    <limit effort="102" lower="-2.3562" upper="2.3562" velocity="3.141592653589793"/>
    <axis xyz="0 -1 0"/>
    <origin rpy="0 0 0" xyz="0.05 0 0.4"/>
    <dynamics damping="120.0" friction="4.0"/>
    <initial_position>0.0</initial_position>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint3"/>
  <transmission name="tran3">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint3">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor3">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link3">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/visual/${nameofManipulator}_link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="2.249"/>
      <inertia ixx="0.022531203" ixy="0" ixz="0" iyy="0.0241792698" iyz="0" izz="0.04505884"/>
      <origin rpy="0 0 0" xyz="0.022215 0.009383 0.074628"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/collision/${nameofManipulator}_link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link3"/>

  <joint name="joint4" type="revolute">
    <parent link="${nameofManipulator}_link3"/>
    <child link="${nameofManipulator}_link4"/>
    <limit effort="16" lower="-3.0543" upper="3.0543" velocity="3.141592653589793"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="-0.05 0 0.4"/>
    <dynamics damping="120.0" friction="4.0"/>
    <initial_position>0.0</initial_position>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint4"/>
  <transmission name="tran4">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint4">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor4">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link4">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/visual/${nameofManipulator}_link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="1.873"/>
      <inertia ixx="0.013281735" ixy="0" ixz="0" iyy="0.012486" iyz="0" izz="0.0231665"/>
      <origin rpy="0 0 0" xyz="-0.0000256 -0.0110398 -0.071513335"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/collision/${nameofManipulator}_link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link4"/>

  <joint name="joint5" type="revolute">
    <parent link="${nameofManipulator}_link4"/>
    <child link="${nameofManipulator}_link5"/>
    <limit effort="16" lower="-3.0543" upper="3.0543" velocity="3.141592653589793"/>
    <axis xyz="0 -1 0"/>
    <origin rpy="0 0 0" xyz="0 0.136 0"/>
    <dynamics damping="120.0" friction="4.0"/>
    <initial_position>0.0</initial_position>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint5"/>
  <transmission name="tran5">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint5">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor5">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link5">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/visual/${nameofManipulator}_link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="1.497"/>
      <inertia ixx="0.04951418" ixy="0" ixz="0" iyy="0.0231432095" iyz="0" izz="0.03931"/>
      <origin rpy="0 0 0" xyz="0.000002932 0.029375 0.0075853"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/collision/${nameofManipulator}_link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link5"/>

  <joint name="joint6" type="revolute">
    <parent link="${nameofManipulator}_link5"/>
    <child link="${nameofManipulator}_link6"/>
    <limit effort="16" lower="-3.0543" upper="3.0543" velocity="3.141592653589793"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0 0 0.1035"/>
    <dynamics damping="120.0" friction="4.0"/>
    <initial_position>0.0</initial_position>
  </joint>
  <xacro:rokae_joint_gazebo joint_name="joint6"/>
  <transmission name="tran6">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint6">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor6">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="${nameofManipulator}_link6">
    <visual>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/visual/${nameofManipulator}_link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="0.652"/>
      <inertia ixx="0.02020952" ixy="0" ixz="0" iyy="0.02021271" iyz="0" izz="0.022936"/>
      <origin rpy="0 0 0" xyz="0.000526 -0.0000352657 -0.044274"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="$(arg mesh_prefix)/${nameofManipulator}/collision/${nameofManipulator}_link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <xacro:rokae_link_gazebo link_ref="${nameofManipulator}_link6"/>

  <ros2_control name="xMateSR4_system" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      <param name="use_sim_time">true</param>
    </hardware>
    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint4">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint5">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint6">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>$(find rokae_hardware)/config/xMateSR4_controllers.yaml</parameters>
    </plugin>
  </gazebo>
</robot>
