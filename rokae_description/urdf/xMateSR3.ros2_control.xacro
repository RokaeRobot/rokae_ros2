<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 控制接口定义宏 -->
  <xacro:macro name="sr3_ros2_control" params="
    xMate_type:=SR3
    robot_ip
    local_ip
    use_fake_hardware:=false
    ">

    <ros2_control name="rokae_hardware_interface" type="system">
      <hardware>
        <xacro:if value="${use_fake_hardware}">
          <plugin>mock_components/GenericSystem</plugin>
          <param name="state_following_offset">0.0</param>
          <param name="robot_ip">${robot_ip}</param>
          <param name="local_ip">${local_ip}</param>
          <param name="xMate_type">${xMate_type}</param>
        </xacro:if>
        <xacro:unless value="${use_fake_hardware}">
          <plugin>rokae_hardware/RokaeHardwareInterface6</plugin>
          <param name="robot_ip">${robot_ip}</param>
          <param name="local_ip">${local_ip}</param>
          <param name="xMate_type">${xMate_type}</param>
        </xacro:unless>
      </hardware>

      <joint name="joint1">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="joint2">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="joint3">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="joint4">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="joint5">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="joint6">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

    </ros2_control>

  </xacro:macro>

</robot>

