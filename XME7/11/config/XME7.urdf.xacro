<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="XME7">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import XME7 urdf file -->
    <xacro:include filename="$(find XME7)/urdf/XME7.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="XME7.ros2_control.xacro" />


    <xacro:XME7_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
